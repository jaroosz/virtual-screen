<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:VirtualScreenViewer"
             x:Class="VirtualScreenViewer.MainPage"
             Title="Virtual Screen Viewer">
    <Grid RowDefinitions="Auto,*" Padding="10">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,*"
              ColumnSpacing="10"
              Padding="0,0,0,10">
            <VerticalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Start">
                <Label Text="Desktop IP Address:" FontSize="14"/>
                <Entry x:Name="IpAddressEntry"
                       Text="192.168.5.91"
                       Placeholder="Enter desktop IP"
                       Keyboard="Default"/>
                <Button x:Name="ConnectButton"
                        Text="Connect"
                        Clicked="OnConnectClicked"
                        HorizontalOptions="Fill"/>
            </VerticalStackLayout>
            <Border Grid.Column="1" Stroke="Gray" StrokeThickness="1" Padding="6" HeightRequest="120">
                <ScrollView x:Name="LogScrollView" VerticalScrollBarVisibility="Always">
                    <Label x:Name="StatusLabel"
                           Text="Not connected"
                           FontSize="12"
                           LineBreakMode="WordWrap"
                           VerticalOptions="Start"/>
                </ScrollView>
            </Border>
        </Grid>

        <Border Grid.Row="1" StrokeThickness="2" Stroke="Gray">
            <local:VideoSurfaceView x:Name="VideoView"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill"/>
        </Border>

    </Grid>
</ContentPage>
